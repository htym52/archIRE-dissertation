---
import Layout from "../layout/layout.astro";
---

<Layout>
    <main class="container">
        <!-- PROFILE HEADER -->
        <header class="profile-header">
            <div class="studio-pfp">
                <img src="rps.jpg" alt="Profile Image" />
            </div>

            <div class="studio-title">
                <h1>Reliable Plumbing Services</h1>
                <p class="studio-location">📍 Dublin, Ireland</p>

                <div class="social-row">
                    <button class="btn-social">🌐 Website</button>
                    <button class="btn-social">🐦 Social</button>
                </div>
            </div>
        </header>

        <!-- ABOUT -->
        <section class="section">
            <h2 class="section-title">About</h2>
            <p class="about-text">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
                eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut
                enim ad minim veniam, quis nostrud exercitation ullamco laboris
                nisi ut aliquip ex ea commodo consequat
            </p>
        </section>

        <!-- FEATURED MEDIA (FIXED CAROUSEL) -->
        <section class="section">
            <h2 class="section-title">Featured</h2>

            <div class="featured-carousel">
                <div class="game-grid">
                    <article class="game-card">
                        <div class="game-art">
                            <img src="FallosophyIllustration.png" alt="" />
                        </div>

                        <div class="game-info">
                            <h3>Fallosophy</h3>
                        </div>
                    </article>

                    <!-- <article class="game-card">
                        <div class="game-art">
                            <img src="media/game2.jpg" alt="">
                        </div>

                        <div class="game-info">
                            <h3>Game 2</h3>
                        </div>
                    </article> -->
                </div>

                <!-- <p class="media-caption">
                    Gameplay footage and early development screenshots.
                </p> -->

                <div class="tag-row">
                    <span class="tag">Indie</span>
                    <span class="tag">Story Rich</span>
                    <span class="tag">Multiplayer</span>
                </div>

                <div class="quick-info">
                    <div><strong>Genre:</strong> Action RPG</div>
                    <div><strong>Platform:</strong> PC</div>
                    <div><strong>Status:</strong> In Development</div>
                    <div><strong>Release:</strong> 2026</div>
                </div>

                <div class="featured-actions">
                    <button class="btn-game-view">▶ Play Demo</button>
                </div>
            </div>

            <!-- GAMES -->
            <!-- <section class="section">
            <h2 class="section-title">Games Showcase</h2>

            <div class="game-grid">

                <article class="game-card">
                    <div class="game-art">
                        <img src="media/game1.jpg" alt="">
                    </div>

                    <div class="game-info">
                        <h3>Game Title</h3>
                        <p>Short description of the game.</p>
                        <button class="btn-game-view">View Game →</button>
                    </div>
                </article>

                <article class="game-card">
                    <div class="game-art">
                        <img src="media/game2.jpg" alt="">
                    </div>

                    <div class="game-info">
                        <h3>Game Title</h3>
                        <p>Short description of the game.</p>
                        <button class="btn-game-view">View Game →</button>
                    </div>
                </article>

            </div> -->
        </section>

        <!-- MEDIA GALLERY -->
        <section class="section">
            <h2 class="section-title">Screenshots / Media</h2>

            <div class="media-grid">
                <div class="media-item">
                    <img src="ClassicsMuralStill.jpg" alt="" />
                </div>

                <div class="media-item">
                    <img src="ClassicsStillBottom.jpg" alt="" />
                </div>

                <div class="media-item">
                    <img src="CaveBridgeStill.jpg" alt="" />
                </div>

                <!-- <div class="media-item">
                    <video src="CaveBridgeStill.jpg" muted autoplay loop></video>
                </div> -->

                <div class="media-item">
                    <img src="EC_Stained_Glass.png" alt="" />
                </div>
            </div>
        </section>

        <!-- COMMENTS -->
        <section class="feedback-box">
            <div class="feedback-header">
                <h2 class="feedback-title">Comments & Feedback</h2>
                <span class="comment-count">2 Comments</span>
            </div>

            <div class="auth-prompt">Login to comment or give feedback.</div>

            <div class="comment">
                <div class="comment-avatar"></div>
                <div>
                    <p class="comment-user">
                        JohnDoe <span class="comment-date">3 days ago</span>
                    </p>
                    <p class="comment-text">
                        Really love the art style of your latest project!
                    </p>
                </div>
            </div>

            <div class="comment">
                <div class="comment-avatar"></div>
                <div>
                    <p class="comment-user">
                        Alice1334 <span class="comment-date">1 week ago</span>
                    </p>
                    <p class="comment-text">Is there a demo available?</p>
                </div>
            </div>
        </section>
    </main>
</Layout>
    