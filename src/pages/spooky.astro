---
import Layout from "../layout/layout.astro";
---

<Layout>
    <main class="container">
        <!-- PROFILE HEADER -->
        <header class="profile-header">
            <div class="studio-pfp">
                <img src="spacelion.png" alt="Profile Image" />
            </div>

            <div class="studio-title">
                <h1>Spooky Doorway</h1>
                <p class="studio-location">📍 Dublin, Ireland</p>

                <div class="social-row">
                    <button class="btn-social">🌐 Website</button>
                    <button class="btn-social">🐦 Social</button>
                </div>
            </div>
        </header>

        <!-- ABOUT -->
        <section class="section">
            <h2 class="section-title">About</h2>
            <p class="about-text">
                Spooky Doorway is an Irish game studio focused on delivering
                narrative-based explorative experiences that aim to respect the
                player’s intelligence and time. What started in 2015 as a
                handful of eejits with big dreams has grown into a remote studio
                of creative, driven, and passionate people, all supporting one
                another in finding fresh stories to bring into the world in
                unique and innovative ways. Whether working in colourful chunky
                pixels, or brooding gothic comic panels, we place heart at the
                centre of everything – how we work, and how we tell our tales.
            </p>
        </section>

        <!-- FEATURED MEDIA (FIXED CAROUSEL) -->
        <section class="section">
            <h2 class="section-title">Featured</h2>

            <div class="featured-carousel">
                <div class="game-grid">
                    <article class="game-card">
                        <div class="game-art">
                            <img src="darkside-detective1.png" alt="" />
                        </div>

                        <div class="game-info">
                            <h3>The Darkside Detective</h3>
                        </div>
                    </article>

                    <!-- <article class="game-card">
                        <div class="game-art">
                            <img src="media/game2.jpg" alt="">
                        </div>

                        <div class="game-info">
                            <h3>Game 2</h3>
                        </div>
                    </article> -->
                </div>

                <p class="media-caption">
                    <!-- Gameplay footage and early development screenshots. -->
                </p>

                <div class="tag-row">
                    <span class="tag">Indie</span>
                    <span class="tag">Story Rich</span>
                    <span class="tag">Multiplayer</span>
                </div>

                <div class="quick-info">
                    <div><strong>Genre:</strong> Mystery</div>
                    <div><strong>Platform:</strong> PC</div>
                    <div><strong>Status:</strong> Released</div>
                    <div><strong>Release:</strong> 2017</div>
                </div>

                <!-- <div class="featured-actions">
                    <button class="btn-game-view">▶ Play Demo</button>
                </div> -->
            </div>

            <!-- GAMES -->
            <!-- <section class="section">
            <h2 class="section-title">Games Showcase</h2>

            <div class="game-grid">

                <article class="game-card">
                    <div class="game-art">
